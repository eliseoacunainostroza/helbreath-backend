HB_ENV=development
HB_LOG_LEVEL=info
HB_LOG_JSON=true
HB_OTEL_ENDPOINT=

HB_GATEWAY_HTTP_BIND=127.0.0.1:7080
HB_GATEWAY_TCP_BIND=0.0.0.0:2848
HB_AUTH_BIND=127.0.0.1:7101
HB_WORLD_BIND=127.0.0.1:7201
HB_MAP_BIND=127.0.0.1:7301
HB_CHAT_BIND=127.0.0.1:7401
HB_ADMIN_BIND=127.0.0.1:8080
HB_JOBS_BIND=127.0.0.1:7501

HB_DATABASE_URL=postgres://hb:hbpass@127.0.0.1:5432/helbreath
HB_DATABASE_MAX_CONN=20

HB_REDIS_ENABLED=false
HB_REDIS_URL=redis://127.0.0.1:6379

HB_MAP_TICK_MS=50
HB_MAP_COMMAND_BUDGET=2048
HB_SESSION_TTL_SECONDS=3600
HB_ADMIN_SESSION_TTL_SECONDS=1800
HB_PACKET_MAX_PAYLOAD=65535
HB_RATE_LIMIT_PER_SEC=40
HB_RATE_LIMIT_BURST=80
HB_GATEWAY_IDLE_TIMEOUT_SECONDS=45
HB_GATEWAY_MAX_CONNECTIONS_PER_IP=32

HB_BOOTSTRAP_ADMIN_EMAIL=admin@localhost
HB_BOOTSTRAP_ADMIN_PASSWORD=change_me_now
