[Unit]
Description=Helbreath Jobs Runner (Rust)
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=hb
Group=hb
WorkingDirectory=/opt/helbreath-backend
EnvironmentFile=/opt/helbreath-backend/.env
ExecStart=/opt/helbreath-backend/bin/hb-jobs-runner
Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
