[Unit]
Description=Helbreath Gateway (Rust)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=hb
Group=hb
WorkingDirectory=/opt/helbreath-backend
EnvironmentFile=/opt/helbreath-backend/.env
ExecStart=/opt/helbreath-backend/bin/hb-gateway
Restart=always
RestartSec=2
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
